generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  orders    Order[]
}

model User {
  id                String        @id @default(cuid())
  username          String        @unique
  passwordHash      String
  displayName       String
  bankAccountNumber String?
  role              Role          @default(USER)
  isFirstLogin      Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  orders              Order[]
  orderPersons        OrderPerson[]
  invitationsSent     Invitation[] @relation("InvitedByUser")
  invitationUsed      Invitation?  @relation("UsedByUser")
}

model Order {
  id                    String          @id @default(cuid())
  restaurant            Restaurant      @relation(fields: [restaurantId], references: [id])
  restaurantId          String
  globalDiscountPercent Float           @default(0)
  createdBy             User            @relation(fields: [createdById], references: [id])
  createdById           String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  feeAdjustments        FeeAdjustment[]
  people                OrderPerson[]
}

model FeeAdjustment {
  id        String @id @default(cuid())
  name      String
  amount    Float
  sortOrder Int
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
}

model OrderPerson {
  id              String           @id @default(cuid())
  name            String
  sortOrder       Int
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String
  user            User?            @relation(fields: [userId], references: [id])
  userId          String?
  items           OrderItem[]
  sharedItemLinks SharedItemLink[]
  customShares    CustomShare[]
}

model OrderItem {
  id              String           @id @default(cuid())
  name            String
  price           Float
  discountPercent Float?
  sortOrder       Int
  person          OrderPerson      @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId        String
  sharedWith      SharedItemLink[]
  customShares    CustomShare[]
}

model SharedItemLink {
  id       String      @id @default(cuid())
  item     OrderItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId   String
  person   OrderPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId String

  @@unique([itemId, personId])
}

model CustomShare {
  id       String      @id @default(cuid())
  item     OrderItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId   String
  person   OrderPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId String
  amount   Float

  @@unique([itemId, personId])
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique
  invitedBy   User      @relation("InvitedByUser", fields: [invitedById], references: [id])
  invitedById String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  usedAt      DateTime?
  usedBy      User?     @relation("UsedByUser", fields: [usedById], references: [id])
  usedById    String?   @unique
}
